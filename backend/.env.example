# ========================================
# Web Browser Rating System - Backend Configuration
# ========================================

# Database Configuration
# For XAMPP/WAMP: DB_PORT=3306, DB_PASSWORD=(empty)
# For standalone MariaDB: DB_PORT=3307, DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=kia101188251388!
DB_NAME=webbrowser_ratings

# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=7d

# CORS Configuration (for development)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Session Configuration
SESSION_SECRET=your_session_secret_change_this
SESSION_MAX_AGE=86400000  # 24 hours

# File Upload Configuration
MAX_FILE_SIZE=5242880  # 5MB
UPLOAD_DIR=uploads